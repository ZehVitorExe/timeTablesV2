generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  password     String      // Senha criptografada
  token        String?     @unique // Token de sessão atual (ex: gerado no login)
  tokenExpires DateTime?   // Data de expiração do token
  createdEvents Event[]     @relation("EventOrganizer")
  joinedEvents  EventUser[]
}

model EventUser {
  eventId  String
  userId   String
  joinedAt DateTime @default(now())
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([eventId, userId])
}

model Event {
  id          String    @id @default(uuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  stages      Stage[]
  tracks      Track[]
  sessions    Session[]
  createdAt   DateTime  @default(now())
  userId      String
  organizer   User        @relation("EventOrganizer", fields: [userId], references: [id], onDelete: Cascade)
  attendees   EventUser[]
}

model Stage {
  id       String    @id @default(uuid())
  name     String
  capacity Int?
  eventId  String
  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sessions Session[]
}

model Track {
  id       String    @id @default(uuid())
  name     String
  color    String?
  eventId  String
  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sessions Session[]
}

model Speaker {
  id       String           @id @default(uuid())
  name     String
  bio      String?
  avatar   String?
  sessions SpeakerSession[]
}

model Session {
  id          String           @id @default(uuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  eventId     String
  event       Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  stageId     String
  stage       Stage            @relation(fields: [stageId], references: [id])
  trackId     String?
  track       Track?           @relation(fields: [trackId], references: [id], onDelete: SetNull)
  speakers    SpeakerSession[] 
}

model SpeakerSession {
  speakerId String
  sessionId String
  speaker   Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@id([speakerId, sessionId])
}
